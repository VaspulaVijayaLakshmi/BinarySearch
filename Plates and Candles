#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    vector<int> platesBetweenCandles(string s, vector<vector<int>>& queries) {
        int n = s.size();
        
        // 1. Prefix sum of plates
        vector<int> prefix(n, 0);
        prefix[0] = (s[0] == '*');
        for (int i = 1; i < n; i++) {
            prefix[i] = prefix[i - 1] + (s[i] == '*');
        }
        
        // 2. Nearest candle to the left
        vector<int> leftCandle(n, -1);
        int last = -1;
        for (int i = 0; i < n; i++) {
            if (s[i] == '|') last = i;
            leftCandle[i] = last;
        }
        
        // 3. Nearest candle to the right
        vector<int> rightCandle(n, -1);
        last = -1;
        for (int i = n - 1; i >= 0; i--) {
            if (s[i] == '|') last = i;
            rightCandle[i] = last;
        }
        
        // 4. Process queries
        vector<int> ans;
        for (auto &q : queries) {
            int l = q[0], r = q[1];
            
            int L = rightCandle[l]; // first candle >= l
            int R = leftCandle[r];  // last candle <= r
            
            if (L != -1 && R != -1 && L < R) {
                ans.push_back(prefix[R] - prefix[L]);
            } else {
                ans.push_back(0);
            }
        }
        
        return ans;
    }
};





